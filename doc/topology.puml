	filter_sokere_tombstone --> KSTREAM_PEEK_0000000009
	KSTREAM_FILTER_0000000014 --> KSTREAM_PEEK_0000000015
	KSTREAM_MAPVALUES_0000000011 --> log_produced_produce_empty_personopplysninger
	KSTREAM_PEEK_0000000009 --> KSTREAM_FOREACH_0000000010
	KSTREAM_PEEK_0000000015 --> KSTREAM_FOREACH_0000000016
	log_produced_produce_empty_personopplysninger --> produce_empty_personopplysninger
}
package "Sub-topology: 1" {
	agent "consume-aap.personopplysninger.v1" <<Source>> as consume_aap_personopplysninger_v1
	agent "log-consume-aap.personopplysninger.v1" <<Processor>> as log_consume_aap_personopplysninger_v1
	agent "filter-personopplysning-tombstones" <<Processor>> as filter_personopplysning_tombstones
	agent "KSTREAM-FILTER-0000000005" <<Processor>> as KSTREAM_FILTER_0000000005
	agent "KSTREAM-PEEK-0000000006" <<Processor>> as KSTREAM_PEEK_0000000006
	agent "KSTREAM-FOREACH-0000000007" <<Processor>> as KSTREAM_FOREACH_0000000007
